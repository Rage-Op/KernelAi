<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.kernel.daemon</string>
  <key>ProgramArguments</key>
  <array>
    <string>__KERNEL_DIR__/launchd/kernel-launch.sh</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>__KERNEL_DIR__/kernel-memory/logs/daemon.out.log</string>
  <key>StandardErrorPath</key><string>__KERNEL_DIR__/kernel-memory/logs/daemon.err.log</string>
</dict>
</plist>
