{
  "name": "kernel-daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "KERNEL — persistent local macOS AI orchestrator daemon (Walking Skeleton)",
  "bin": {
    "kernel": "scripts/chat.mjs",
    "kernel-mcp": "scripts/kernel-mcp.mjs"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/write-build-stamp.mjs",
    "build:web": "tsc -p ../webface/tsconfig.json && cp ../webface/index.html ../webface/styles.css ../webface/dist/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "heartbeat": "node dist/index.js --heartbeat",
    "chat": "node scripts/chat.mjs",
    "status": "node scripts/kernel-status.mjs",
    "mcp": "node scripts/kernel-mcp.mjs",
    "test": "tsx --test \"src/**/*.test.ts\" \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.105.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3-multiple-ciphers": "12.11.1",
    "gray-matter": "4.0.3",
    "pino": "10.3.1",
    "plaid": "42.2.0",
    "playwright": "1.61.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "pino-pretty": "13.1.3",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
