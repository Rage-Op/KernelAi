# KERNEL daemon environment
# Copy to `.env` and fill in. Loaded via Node 24 native --env-file=.env.

# Anthropic API key for the Claude brain.
# REFERENCED but UNUSED in Phase 1 — no API calls are made by the skeleton.
# (Lands here so the BrainProvider/Decision shape aligns with the real SDK.)
ANTHROPIC_API_KEY=

# Absolute path to the kernel-memory/ git repo.
# Defaults to the sibling ../kernel-memory resolved from the daemon if unset.
KERNEL_MEMORY_DIR=
